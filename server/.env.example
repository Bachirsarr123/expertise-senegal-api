# =============================================================
# VARIABLES D'ENVIRONNEMENT - A configurer dans Render Dashboard
# =============================================================

# --- Base de données TiDB Cloud ---
# Récupérer ces valeurs dans : TiDB Cloud > Cluster > Connect > Node.js
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=<votre-utilisateur-tidb>
DB_PASSWORD=<votre-mot-de-passe-tidb>
DB_NAME=expertise_senegal
DB_SSL=true

# --- Sécurité JWT ---
# Générer un secret fort : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<changez-par-un-secret-fort-minimum-32-caracteres>

# --- Port (Render le définit automatiquement - ne pas changer) ---
PORT=10000

# --- Frontend (pour CORS) ---
# Mettre l'URL exacte de votre site OVH (sans slash final)
FRONTEND_URL=https://expertisesenegal.com

# --- Email SMTP ---
# Option 1 : Gmail avec "Mot de passe d'application"
# (Compte Google > Sécurité > Validation en 2 étapes > Mots de passe des applications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=<votre-adresse@gmail.com>
MAIL_PASS=<mot-de-passe-application-16-caracteres>
MAIL_FROM=Expertise Sénégal <contact@expertisesenegal.com>

# Option 2 : SMTP OVH (si vous avez un compte email OVH)
# MAIL_HOST=ssl0.ovh.net
# MAIL_PORT=587
# MAIL_USER=contact@expertisesenegal.com
# MAIL_PASS=<votre-mot-de-passe-email-ovh>
# MAIL_FROM=Expertise Sénégal <contact@expertisesenegal.com>
